# ============================================================
# enockey-site 環境変数テンプレート
# ============================================================
# このファイルをコピーして .env.local を作成し、実際の値を入力してください
# cp .env.example .env.local
# ============================================================

# Cloudinary - 画像管理・配信サービス (https://cloudinary.com)
# 取得場所: ダッシュボード > Settings > API Keys
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name_here

# Resend - メール送信サービス (https://resend.com)
# 取得場所: ダッシュボード > API Keys > Create API Key
RESEND_API_KEY=your_api_key_here
